package components

templ Card(id, background string) {
	<section
		id={ id }
		class={
			"bg-exotic-skin",
			"w-full",
			"h-screen",
			"p-[2.5vw]",
			"snap-start",
		}
	>
		<div
			class={
				background,
				"size-full",
				"rounded-4xl",
				"flex",
				"flex-col",
				"items-center",
				"justify-center",
			}
		>
			{ children... }
		</div>
	</section>
}
